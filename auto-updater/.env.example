# Copy this file to .env for local testing
# On Railway — add these directly in environment variables settings (not via file)

SHOP_DOMAIN=sgcsilver.myshopify.com
CLIENT_ID=your_shopify_client_id_here
CLIENT_SECRET=your_shopify_client_secret_here

# metals.dev API key — get yours at https://metals.dev
METALS_API_KEY=your_metals_dev_api_key_here

# How often to run (in hours) — 1 = every hour, 0.5 = every 30 min
INTERVAL_HOURS=1
